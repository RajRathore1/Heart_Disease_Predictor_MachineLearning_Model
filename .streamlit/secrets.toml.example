# Copy this file to .streamlit/secrets.toml (gitignored) and fill in real
# values to enable high-risk email alerts. On Streamlit Community Cloud, add
# the same keys via the app's Settings -> Secrets panel instead of a file.
#
# Without this configured, the app runs fine - the "Notify email" field on
# the single-prediction page is simply hidden.

[smtp]
host = "smtp.gmail.com"
port = 587
sender_email = "alerts@example.com"
# For Gmail, use an App Password (not your normal password):
# https://support.google.com/accounts/answer/185833
sender_password = "app-specific-password"

# OPTIONAL - permanent hosted database (recommended for production).
# Without this, history is stored in a local SQLite file, which Streamlit
# Cloud wipes on every redeploy/restart. Create a free Postgres project at
# https://supabase.com or https://neon.tech and paste its connection string:
#
# [database]
# url = "postgresql://USER:PASSWORD@HOST:5432/postgres"
